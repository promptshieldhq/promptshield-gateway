# PromptShield gateway configuration — EXAMPLE

# --- Gateway ---
PROMPTSHIELD_PORT=8080
PROMPTSHIELD_CHAT_ROUTE=/v1/chat/completions
# PROMPTSHIELD_ADMIN_TOKEN=dev-gateway-admin-token  # required for /admin/config and /admin/policy
# PROXY_ADMIN_TOKEN=dev-proxy-admin-token           # legacy fallback (deprecated)
# PROMPTSHIELD_TRUST_PROXY_CIDRS=10.0.0.0/8,192.168.0.0/16  # trust X-Real-IP only from these forwarding source ranges
# PROMPTSHIELD_EXPOSE_METRICS_ON_MAIN_PORT=false             # unsafe when true: exposes unauthenticated /metrics on public listener
# PROMPTSHIELD_METRICS_ADDR=127.0.0.1:9090                  # preferred: bind /metrics to an internal-only listener

# --- Detection engine ---
# PROMPTSHIELD_ENGINE_URL=http://localhost:4321   # enable detection engine
# gateway mode (no scanning)
PROMPTSHIELD_ENGINE_URL=none
# Bearer token forwarded to engine — must match PROMPTSHIELD_API_KEY in promptshield-engine.
# Required when PROMPTSHIELD_ALLOW_UNAUTH=false on the engine (the default).
# PROMPTSHIELD_ENGINE_API_KEY=dev-engine-key
# PII_SCORE_THRESHOLD=0.5                         # set in the engine process, not the gateway

# --- Upstream provider (single-provider mode) ---
# Supported: gemini | openai | anthropic | openai-compatible | selfhosted
PROMPTSHIELD_PROVIDER=gemini

# Provider base URL override (single-provider mode only)
# PROMPTSHIELD_UPSTREAM_URL=https://generativelanguage.googleapis.com/v1beta

# --- Multi-provider mode ---
# Set PROMPTSHIELD_PROVIDERS to enable routing by model name.
# The first provider listed is the fallback when no model matches.
# PROMPTSHIELD_PROVIDERS=gemini,openai
# PROMPTSHIELD_PROVIDERS=anthropic,openai,gemini
# PROMPTSHIELD_PROVIDERS=gemini,openai,selfhosted

# Per-provider URL overrides (used in multi-provider mode):
# PROMPTSHIELD_GEMINI_UPSTREAM_URL=https://generativelanguage.googleapis.com/v1beta
# PROMPTSHIELD_OPENAI_UPSTREAM_URL=https://api.openai.com/v1
# PROMPTSHIELD_ANTHROPIC_UPSTREAM_URL=https://api.anthropic.com/v1
# PROMPTSHIELD_SELFHOSTED_UPSTREAM_URL=http://localhost:11434/v1
# PROMPTSHIELD_OPENAI_COMPATIBLE_UPSTREAM_URL=http://my-gateway/v1

# Custom model routes — map specific model names (or prefixes) to a provider.
# Built-in rules: gpt-* / o1* / o3* → openai, gemini-* → gemini.
# Use this to override or add routes for custom model names.
# PROMPTSHIELD_MODEL_ROUTES=llama3=selfhosted,mistral=openai-compatible

# --- Model selection ---
# No default model is set. Configure one here or pass model in every request.
# PROMPTSHIELD_MODEL=                            # global override (all providers)
# PROMPTSHIELD_GEMINI_MODEL=gemini-2.0-flash
# PROMPTSHIELD_OPENAI_MODEL=gpt-4o-mini
# PROMPTSHIELD_ANTHROPIC_MODEL=claude-sonnet-4-5
# PROMPTSHIELD_SELFHOSTED_MODEL=llama3.1:8b
# PROMPTSHIELD_OPENAI_COMPATIBLE_MODEL=

# --- API keys ---
# Prefer injecting keys at request time via x-llm-api-key or Authorization: Bearer <key>.
# These env vars are the server-side fallback (useful for single-tenant deployments).
#
# Multiple keys are supported via comma-separated values — the gateway rotates through
# them in round-robin order, which spreads load and avoids per-key rate limits.
#
# PROMPTSHIELD_UPSTREAM_API_KEY=key1,key2,key3   # global fallback (single-provider mode)
# GEMINI_API_KEY=key1,key2,key3
# OPENAI_API_KEY=key1,key2,key3
# ANTHROPIC_API_KEY=sk-ant-api03-xxxx
# SELFHOSTED_API_KEY=key1                        # optional for local/self-hosted endpoints

# --- Policy ---
# PROMPTSHIELD_POLICY_PATH=config/policy.yaml
# PROMPTSHIELD_ALLOW_DEFAULT_POLICY=false         # unsafe when true: allows startup with fallback allow-all policy

# --- Audit ---
# PROMPTSHIELD_AUDIT_URL=https://your-dashboard.example.com  # enable HTTP audit push
# AUDIT_INGEST_SECRET=your-secret-here                       # bearer token sent as x-ingest-secret header to the audit ingest endpoint

# --- OpenClaw integration ---
# No gateway changes needed. Copy examples/openclaw.json to ~/.openclaw/openclaw.json.
# Rate limiting is disabled by default — enable it in config/policy.yaml if needed.
